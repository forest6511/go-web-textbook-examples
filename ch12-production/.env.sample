# ch12-production 起動に必要な環境変数のサンプル。
#
# 使い方:
#   cp .env.sample .env
#   .env に実値を入れてから `set -a && source .env && set +a && go run ./cmd/api`
#
# `.env` は .gitignore で除外済み（公開リポに DSN・Secret を上げない）。

# アプリ環境: development / staging / production
APP_ENV=development

# リッスンポート。Cloud Run / Fly.io は PORT を自動で設定する
PORT=8080

# Postgres 接続文字列（compose.yaml の db サービスに合わせた既定）
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable

# 起動時にマイグレーションを流す場合 true（Ch 04 由来）
RUN_MIGRATIONS=true

# JWT 署名鍵（32 文字以上必須）。本番はランダム生成して Secret Manager に入れる
JWT_SECRET=change-me-to-a-random-32+-char-secret

# Sentry DSN（Ch 12 で取得する値）。空なら Sentry は no-op
# 例: https://<public_key>@o<org_id>.ingest.us.sentry.io/<project_id>
SENTRY_DSN=

# S3 互換ストレージ（Ch 08 由来。空なら AWS S3 デフォルト認証チェーン）
AWS_REGION=ap-northeast-1
S3_BUCKET=uploads
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OTel Collector エンドポイント（Ch 09 由来。未設定時は送信無効化）
OTEL_EXPORTER_OTLP_ENDPOINT=
